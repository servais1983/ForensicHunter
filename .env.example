# ============================================================
# ForensicHunter — Environment configuration template
# Copy to .env and fill in values before starting the server.
# Never commit .env to version control.
# ============================================================

# Environment: development | staging | production
FORENSICHUNTER_ENV=production

# API authentication secret (min 32 chars, randomly generated)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
API_SECRET_KEY=

# Comma-separated list of allowed CORS origins (leave empty to deny all)
# Example: https://dashboard.example.com,https://soc.example.com
ALLOWED_ORIGINS=

# Optional: VirusTotal API key for threat intelligence enrichment
VIRUSTOTAL_API_KEY=

# Optional: SIEM webhook endpoint
SIEM_ENDPOINT=

# Optional: Sentry DSN for error tracking
SENTRY_DSN=

# Optional: PostgreSQL connection string for persistent storage
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/forensichunter

# Optional: Redis URL for task queue / caching
REDIS_URL=redis://localhost:6379/0
